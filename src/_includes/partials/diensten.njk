{% from "partials/icoon.njk" import icoon %}
{% if diensten.zichtbaar %}
  <section id="diensten" class="section">
    <div class="container">
      <p class="section-label">{{ diensten.label }}</p>
      <h2>{{ diensten.titel }}</h2>
      <p class="section-lead">{{ diensten.tekst }}</p>

      <div class="card-grid">
        {% for item in diensten.lijst %}
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              {{ icoon(item.icoon) }}
            </div>
            <h3>{{ item.titel }}</h3>
            <p>{{ item.tekst }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
