<header class="site-header" id="top">
  <div class="container header-inner">
    <a href="#top" class="brand">
      <span class="brand-mark">{{ site.initialen }}</span>
      <span class="brand-text">{{ site.bedrijfsnaam }}<small>{{ site.ondertitel }}</small></span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu openen" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" id="mainNav">
      {% for blok in blokken.lijst %}
        {% if blok.zichtbaar and blok.in_menu %}<a href="#{{ blok.anker }}">{{ blok.menutekst }}</a>{% endif %}
      {% endfor %}
      {% if contact.zichtbaar %}<a href="#contact">Contact</a>{% endif %}
      <a href="tel:{{ site.telefoon_link }}" class="nav-cta">{{ site.telefoon }}</a>
    </nav>
  </div>
</header>
