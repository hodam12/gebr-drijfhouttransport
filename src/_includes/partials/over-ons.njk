{% if overOns.zichtbaar %}
  <section id="over-ons" class="section about">
    <div class="container about-grid">
      <div class="about-media">
        {% afbeelding overOns.afbeelding, overOns.afbeelding_alt %}
      </div>
      <div class="about-text">
        <p class="section-label">{{ overOns.label }}</p>
        <h2>{{ overOns.titel }}</h2>
        {% for alinea in overOns.teksten %}
          <p>{{ alinea }}</p>
        {% endfor %}
        <ul class="about-list">
          {% for punt in overOns.punten %}
            <li>{{ punt }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>
{% endif %}
