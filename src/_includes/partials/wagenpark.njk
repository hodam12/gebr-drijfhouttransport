{% if wagenpark.zichtbaar %}
  <section id="wagenpark" class="section section-alt">
    <div class="container">
      <p class="section-label">{{ wagenpark.label }}</p>
      <h2>{{ wagenpark.titel }}</h2>
      <p class="section-lead">{{ wagenpark.tekst }}</p>

      <div class="gallery" id="gallery">
        {% for foto in wagenpark.fotos %}
          {% galerijFoto foto.afbeelding, foto.alt %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
